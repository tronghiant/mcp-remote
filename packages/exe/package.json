{
  "name": "@mcp-remote/exe",
  "version": "0.1.29",
  "description": "MCP Remote proxy bundled as standalone executables for different platforms",
  "keywords": [
    "mcp",
    "stdio",
    "sse", 
    "remote",
    "oauth",
    "executable"
  ],
  "license": "MIT",
  "repository": "https://github.com/tronghiant/mcp-remote/tree/main/packages/exe",
  "homepage": "https://github.com/tronghiant/mcp-remote/tree/main/packages/exe#readme",
  "bugs": {
    "url": "https://github.com/tronghiant/mcp-remote/issues"
  },
  "scripts": {
    "preinstall": "node setup.js",
    "prepare": "node prepare.js"
  },
  "optionalDependencies": {
    "@mcp-remote/linux-x64": "workspace:*",
    "@mcp-remote/macos-arm64": "workspace:*",
    "@mcp-remote/macos-x64": "workspace:*",
    "@mcp-remote/win-x64": "workspace:*"
  },
  "preferGlobal": true,
  "publishConfig": {
    "bin": {
      "mcp-remote": "mcp-remote",
      "mcp-remote-client": "mcp-remote-client"
    }
  }
}